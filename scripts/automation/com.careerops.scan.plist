<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.careerops.scan</string>
  <key>ProgramArguments</key>
  <array>
    <string>__REPO__/scripts/automation/daily-scan.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__REPO__/data/launchd-scan.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO__/data/launchd-scan.log</string>
  <key>WorkingDirectory</key>
  <string>__REPO__</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
